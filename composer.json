{
	"name": "celemas/router",
	"description": "PSR-7/PSR-15 router and dispatcher",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celemas.dev"
		}
	],
	"homepage": "https://celemas.dev/router",
	"autoload": {
		"psr-4": {
			"Celemas\\Router\\": "src/"
		},
		"files": [
			"src/Utils.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Celemas\\Router\\Tests\\": "tests/"
		},
		"files": [
			"tests/Fixtures/globalTestSymbols.php"
		]
	},
	"require": {
		"php": "^8.5",
		"celemas/wire": "v0.5.0",
		"psr/container": "^2.0",
		"psr/http-message": "^1.1 || ^2.0",
		"psr/http-message-implementation": "^1.0",
		"psr/http-server-handler": "^1.0",
		"psr/http-server-middleware": "^1.0"
	},
	"require-dev": {
		"celemas/dev": "^4.1",
		"laminas/laminas-diactoros": "^3.3"
	},
	"scripts": {
		"test": "./vendor/bin/phpunit --testdox --no-coverage --colors=always",
		"types": "./vendor/bin/psalm --no-cache",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"docs:format": "npx prettier@3.6.2 --write --config ./docs/.prettierrc README.md CHANGELOG.md LICENSE.md docs/",
		"docs:lint": "npx markdownlint-cli2@0.22.1 --config ./vendor/celemas/dev/config/markdownlint.jsonc README.md CHANGELOG.md LICENSE.md docs/",
		"coverage": [
			"./vendor/bin/phpunit --testdox --path-coverage --coverage-text --coverage-php=.coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer .coverage/cover.php"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer types",
			"composer docs:lint"
		]
	}
}
